{
	"name": "@newton-xyz/policy-pack-shared",
	"version": "0.1.1",
	"description": "Shared TypeScript contract for Newton policy packs. Defines the PolicyPack<Params, WasmArgs, Secrets> interface that @newton-xyz/newton-shield-sdk consumes.",
	"license": "Apache-2.0",
	"author": "Newton Protocol <https://x.com/newton_xyz> (https://newton.xyz)",
	"homepage": "https://github.com/newt-foundation/newton-policy-packs/tree/main/packages/policy-pack-shared",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/newt-foundation/newton-policy-packs.git",
		"directory": "packages/policy-pack-shared"
	},
	"bugs": {
		"url": "https://github.com/newt-foundation/newton-policy-packs/issues"
	},
	"keywords": [
		"newton",
		"newton-protocol",
		"policy-pack",
		"shield",
		"vault",
		"curator"
	],
	"publishConfig": {
		"access": "public"
	},
	"sideEffects": false,
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"test": "echo 'no tests yet'"
	},
	"peerDependencies": {
		"viem": "^2.0.0",
		"zod": "^3.0.0"
	},
	"devDependencies": {
		"tsup": "^8.5.1",
		"typescript": "^5.5.0",
		"viem": "^2.0.0",
		"zod": "^3.23.0"
	}
}

{
	"name": "@newton-xyz/policy-pack-guardrail",
	"version": "2.0.7",
	"description": "Bindings-only Newton guardrail policy pack (zod schemas + deployments). No PolicyPack export yet — use with NewtonShield.guardedCall until pack.ts lands.",
	"license": "Apache-2.0",
	"author": "Newton Protocol <https://x.com/newton_xyz> (https://newton.xyz)",
	"homepage": "https://github.com/newt-foundation/newton-policy-packs/tree/main/packages/policy-pack-guardrail",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/newt-foundation/newton-policy-packs.git",
		"directory": "packages/policy-pack-guardrail"
	},
	"bugs": {
		"url": "https://github.com/newt-foundation/newton-policy-packs/issues"
	},
	"keywords": [
		"newton",
		"newton-protocol",
		"policy-pack",
		"shield",
		"guardrail"
	],
	"publishConfig": {
		"access": "public"
	},
	"sideEffects": false,
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"test": "node --import tsx --test src/*.test.ts"
	},
	"peerDependencies": {
		"@newton-xyz/policy-pack-shared": "^0.4.5",
		"viem": "^2.0.0",
		"zod": "^3.0.0"
	},
	"devDependencies": {
		"@newton-xyz/policy-pack-shared": "workspace:*",
		"tsup": "^8.5.1",
		"tsx": "^4.19.0",
		"typescript": "^5.5.0",
		"viem": "^2.0.0",
		"zod": "^3.23.0"
	}
}
